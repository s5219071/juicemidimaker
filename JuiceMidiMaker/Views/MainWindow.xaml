<Window x:Class="JuiceMidiMaker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:JuiceMidiMaker.Views"
        Title="JuiceMidiMaker"
        Width="1360"
        Height="860"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="24,18,20,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,16">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="JUICE MIDI MAKER"
                               FontFamily="Consolas"
                               FontWeight="Bold"
                               FontSize="26"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="BBT SAMPLE SEQUENCER  /  designed by Kino"
                               FontFamily="Consolas"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Text="16 BARS  |  1/16 GRID  |  960 PPQ"
                           FontFamily="Consolas"
                           Foreground="{StaticResource TextMutedBrush}" />
            </DockPanel>

            <Border Grid.Row="1"
                    Margin="0,0,0,18"
                    Padding="12"
                    Background="{StaticResource BgSecondaryBrush}"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding LoadSampleCommand}"
                            Content="LOAD SAMPLE" />
                    <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SampleFileName}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="One-shot WAV / MP3 / AIFF"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="BPM" VerticalAlignment="Center" Margin="8,0,5,0" />
                        <TextBox Width="54"
                                 Style="{StaticResource DarkTextBoxStyle}"
                                 Margin="0"
                                 Text="{Binding Bpm, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="NOTE 0-127" VerticalAlignment="Center" Margin="12,0,5,0" />
                        <TextBox Width="42"
                                 Style="{StaticResource DarkTextBoxStyle}"
                                 Margin="0"
                                 Text="{Binding MidiNoteNumber, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="VEL 0-127" VerticalAlignment="Center" Margin="12,0,5,0" />
                        <TextBox Width="42"
                                 Style="{StaticResource DarkTextBoxStyle}"
                                 Margin="0"
                                 Text="{Binding Velocity, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="12"
                    Background="#141414"
                    BorderBrush="#343434"
                    BorderThickness="1"
                    CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding BarGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="6"
                                        Background="#181818"
                                        BorderBrush="#343434"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0"
                                                   Margin="2,0,0,4"
                                                   Text="{Binding Label}"
                                                   FontFamily="Consolas"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}" />
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Bars}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="4" Rows="1" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="2"
                                                            Padding="3"
                                                            Background="#202020"
                                                            BorderBrush="#454545"
                                                            BorderThickness="1"
                                                            CornerRadius="2">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0"
                                                                       Margin="1,0,0,3"
                                                                       Text="{Binding BarNumber, StringFormat=BAR {0}}"
                                                                       FontFamily="Consolas"
                                                                       FontSize="9"
                                                                       Foreground="{StaticResource TextMutedBrush}" />
                                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Steps}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <UniformGrid Columns="16" Rows="1" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button Command="{Binding DataContext.ToggleStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}"
                                                                                Margin="1"
                                                                                Padding="0">
                                                                            <Button.ToolTip>
                                                                                <StackPanel>
                                                                                    <TextBlock Text="{Binding BarNumber, StringFormat=Bar {0}}" />
                                                                                    <TextBlock Text="{Binding StepInBar, StringFormat=Step {0}}" />
                                                                                </StackPanel>
                                                                            </Button.ToolTip>
                                                                            <Button.Style>
                                                                                <Style TargetType="Button">
                                                                                    <Setter Property="Background" Value="{Binding IsActive, Converter={StaticResource BoolToColorConverter}}" />
                                                                                    <Setter Property="BorderBrush" Value="#444444" />
                                                                                    <Setter Property="BorderThickness" Value="1" />
                                                                                    <Setter Property="Cursor" Value="Hand" />
                                                                                    <Setter Property="Template">
                                                                                        <Setter.Value>
                                                                                            <ControlTemplate TargetType="Button">
                                                                                                <Border x:Name="StepBorder"
                                                                                                        MinHeight="28"
                                                                                                        Background="{TemplateBinding Background}"
                                                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                                                        CornerRadius="1" />
                                                                                                <ControlTemplate.Triggers>
                                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                                        <Setter TargetName="StepBorder" Property="Opacity" Value="0.78" />
                                                                                                    </Trigger>
                                                                                                </ControlTemplate.Triggers>
                                                                                            </ControlTemplate>
                                                                                        </Setter.Value>
                                                                                    </Setter>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsBeat}" Value="True">
                                                                                            <Setter Property="BorderBrush" Value="#777777" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsPlayhead}" Value="True">
                                                                                            <Setter Property="BorderBrush" Value="{StaticResource PlayheadBorderBrush}" />
                                                                                            <Setter Property="BorderThickness" Value="2" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Width="90"
                            Command="{Binding TogglePlaybackCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                <Setter Property="Content" Value="PLAY" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Content" Value="STOP" />
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ClearPatternCommand}"
                            Content="CLEAR" />
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding CreateFourOnFloorCommand}"
                            Content="4 ON FLOOR" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="16,0"
                           VerticalAlignment="Center"
                           Text="{Binding StatusMessage}"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource TextMutedBrush}" />

                <Button Grid.Column="2"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="{StaticResource AccentBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        Command="{Binding ExportMidiCommand}"
                        Content="EXPORT MIDI" />
            </Grid>
        </Grid>

        <views:PresetManagerPanel Grid.Column="1" DataContext="{Binding}" />
    </Grid>
</Window>
